APP_DOMAIN=demo.example.com
LETSENCRYPT_EMAIL=ops@example.com
AWS_REGION=us-east-1

# Optional for no-EIP dynamic DNS mode.
# If set, startup and periodic sync scripts will UPSERT APP_DOMAIN -> current public IPv4.
ROUTE53_HOSTED_ZONE_ID=
ROUTE53_RECORD_TTL=60

# Optional startup behavior.
AUTO_CERTBOT_ON_STARTUP=false
EC2_APP_USER=ubuntu
WORKDAY_TIMEZONE=America/Toronto
# Instance start/stop should be managed by EventBridge Scheduler only.
# Configure schedules via setup-ec2-workday-scheduler.sh.

MYSQL_ROOT_PASSWORD=root_pass
MYSQL_APP_USER=app
MYSQL_APP_PASSWORD=app_pass

RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=admin123

MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=admin123

SANDBOX_JWT_SECRET=change-me-in-production
SANDBOX_REDIS_PASSWORD=

SANDBOX_MONGO_ENABLED=true
SANDBOX_MONGO_DATABASE=upo_audit
SANDBOX_MONGO_COLLECTION=order_event_timeline

GATEWAY_LOGIN_RATE_LIMIT_MAX_REQUESTS=10
GATEWAY_LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
GATEWAY_ORDER_CREATE_RATE_LIMIT_MAX_REQUESTS=20
GATEWAY_ORDER_CREATE_RATE_LIMIT_WINDOW_SECONDS=60

COMPOSE_PROJECT_NAME=modern-upo-online
